# =============================================================================
# Nightshade 2.0 .gitignore
# =============================================================================

# =============================================================================
# AI/Agent Tools
# =============================================================================
.agent/
.claude/
.cursor/
.aider*
.continue/
CLAUDE.md

# =============================================================================
# Vendor firmware research blobs (excluded from git per release audit
# release-pr-lists/04-defer-exclude.txt; oversized .DAT files violate GitHub's
# 100 MB hard limit. Files remain on disk for local research use.)
# =============================================================================
_fw_research/

# =============================================================================
# Internal release-engineering scratch (audit tool outputs, scratch scripts,
# stale build-output DLLs). Kept locally for the maintainer; not relevant for
# a downstream contributor building from source.
# =============================================================================

# Root-level audit tool outputs
.audit_highrisk*.txt
.audit_hits*.txt
.behavioral_audit_hits.txt
.ui_consistency_audit.txt

# Root-level scratch / one-off ad-hoc helpers
_old_marker.txt
_patch_caps.py
package-log.txt
goal.txt

# Internal report / audit / planning trees
/report/
/reports/
/docs/audits/
/docs/code-quality/
/docs/plans/
/docs/production-readiness/
/docs/science_mockups/
/docs/frb_warnings_*.txt

# Build-output DLLs that get re-emitted by cargo + the packaging script.
# The single canonical libraw.dll the installer consumes lives at
# apps/desktop/windows/runner/Release/libraw.dll and is whitelisted below.
apps/desktop/*.dll
apps/desktop/windows/*.dll
apps/desktop/windows/runner/*.dll
apps/desktop/windows/runner/Debug/*.dll
apps/desktop/windows/runner/Release/*.dll
!apps/desktop/windows/runner/Release/libraw.dll

# Build-log scratch dir used by release packaging scripts
/build-logs/

# =============================================================================
# IDE and Editors
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# =============================================================================
# Dart/Flutter
# =============================================================================
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
*.iml

# Generated code markers (keep generated files, ignore markers)
*.g.dart.info
*.freezed.dart.info

# Flutter specific
**/android/.gradle/
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.*
**/ios/Flutter/.last_build_id
**/ios/.generated/
**/ios/Flutter/App.framework/
**/ios/Flutter/Flutter.framework/
**/ios/Flutter/Flutter.podspec
**/ios/Pods/
**/ios/Runner/GeneratedPluginRegistrant.*

# =============================================================================
# Rust
# =============================================================================
**/target/
**/*.rs.bk
Cargo.lock

# Negation: the Dart models/target/ directory holds source files (catalog
# target types), not Rust build output. Without this, **/target/ above swallows
# target_models.dart and the package fails to compile from a fresh clone.
!packages/nightshade_core/lib/src/models/target/
!packages/nightshade_core/lib/src/models/target/**

# But keep Cargo.lock for apps (not libraries) - uncomment if needed:
# !apps/**/Cargo.lock

# =============================================================================
# Native/Compiled Binaries
# =============================================================================
# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries (at root and build folders)
/*.dll
/*.so
/*.dylib

# Compiled Static libraries
/*.lai
/*.la
/*.a
/*.lib

# BUT track lib/ directory for required dependencies (LibRaw, etc.)
!lib/
!lib/**

# Executables
*.exe
*.out
*.app

# Fortran module files
*.mod
*.smod

# =============================================================================
# Vendor SDKs (large binary dependencies)
# =============================================================================
SDKs/

# =============================================================================
# Logs and Temporary Files
# =============================================================================
logs/
*.log
*.tmp
*.temp
nul
build_output.txt
temp_*.txt

# =============================================================================
# Development/Debug Scripts (root level)
# =============================================================================
# Temporary PowerShell scripts
check_*.ps1
find_*.ps1
verify_*.ps1
test_*.ps1

# Temporary fix scripts
fix_*.sh
fix_*.py

# Temporary Dart test scripts (root level only)
/test_*.dart
/inspect_*.dart

# =============================================================================
# Documentation (AI-generated implementation notes - not core docs)
# =============================================================================
# Keep these out of version control - they're development notes
*_IMPLEMENTATION.md
*_IMPLEMENTATION_SUMMARY.md
*_README.md
NOT_IMPLEMENTED_FIXES.md

# But DO track the docs/ folder and CLAUDE.md
!docs/
!CLAUDE.md

# =============================================================================
# OS-Specific
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# =============================================================================
# Workspace Files
# =============================================================================
*.code-workspace

# =============================================================================
# Secrets and Environment
# =============================================================================
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
secrets.yaml
secrets.json

# =============================================================================
# Profiles and User Data
# =============================================================================
profiles/

# =============================================================================
# Coverage and Test Reports
# =============================================================================
coverage/
.test_coverage/
lcov.info
*.lcov

# =============================================================================
# Miscellaneous
# =============================================================================
*.d
.melos_tool/
nightshade.db
.worktrees/
